# =============================================================================
#  NSU AUDIT — Environment Template
#  This file is safe to commit. It shows required variables with no real values.
#  To use: cp .env.example .env  then fill in your actual credentials.
# =============================================================================

# Google OAuth — Web Client
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=GOCSPX-your-web-client-secret

# Google OAuth — CLI Client (Desktop App)
GOOGLE_CLI_CLIENT_ID=your-cli-client-id.apps.googleusercontent.com
GOOGLE_CLI_CLIENT_SECRET=GOCSPX-your-cli-client-secret

# Google OAuth — Shared Config
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
GOOGLE_ALLOWED_HD=northsouth.edu

# Session / JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Database (PostgreSQL)
DATABASE_URL=postgresql://nsu_audit:changeme@localhost:5432/nsu_audit_db
POSTGRES_USER=nsu_audit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nsu_audit_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
APP_ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=/tmp/nsu_audit_uploads
MAX_UPLOAD_SIZE_MB=10

# Security
CORS_ALLOWED_ORIGINS=http://localhost:5173
